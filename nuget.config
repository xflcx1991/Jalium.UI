<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="Local" value="./packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <!--
    Disable a stale per-user source that points at $(JaliumUIBuildBinRelease).
    The path "...\Jalium.UI.Build\bin\Release" only exists after a Release build
    of Jalium.UI.Build, so any Debug-only restore (or fresh clone) trips NU1301.
    The "Local" source above already aggregates every Jalium.* nupkg via
    `./packages/`, so JaliumLocal is fully redundant. Disabling it here scopes
    the override to this repo without touching the per-user NuGet.Config.
  -->
  <disabledPackageSources>
    <add key="JaliumLocal" value="true" />
  </disabledPackageSources>
</configuration>
