<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    Jalium.UI.Build 属性配置
    此文件在项目属性定义之前导入
  -->

  <PropertyGroup>
    <!-- 启用 JALXAML 默认项发现 -->
    <_JalxamlOutputConfigurationSegment Condition="'$(_JalxamlOutputConfigurationSegment)' == '' and '$(Configuration)' != ''">$(Configuration)\</_JalxamlOutputConfigurationSegment>
    <_JalxamlOutputTargetFrameworkSegment Condition="'$(_JalxamlOutputTargetFrameworkSegment)' == '' and '$(TargetFramework)' != ''">$(TargetFramework)\</_JalxamlOutputTargetFrameworkSegment>
    <_JalxamlOutputRuntimeIdentifierSegment Condition="'$(_JalxamlOutputRuntimeIdentifierSegment)' == '' and '$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier)\</_JalxamlOutputRuntimeIdentifierSegment>
    <_JalxamlDefaultIntermediateOutputPath Condition="'$(_JalxamlDefaultIntermediateOutputPath)' == ''">$(MSBuildProjectExtensionsPath)$(_JalxamlOutputConfigurationSegment)$(_JalxamlOutputTargetFrameworkSegment)$(_JalxamlOutputRuntimeIdentifierSegment)Jalxaml\</_JalxamlDefaultIntermediateOutputPath>
    <JalxamlIntermediateOutputPath Condition="'$(JalxamlIntermediateOutputPath)' == ''">$(_JalxamlDefaultIntermediateOutputPath)</JalxamlIntermediateOutputPath>
    <_JalxamlUsesDefaultIntermediateOutputPath Condition="'$(JalxamlIntermediateOutputPath)' == '$(_JalxamlDefaultIntermediateOutputPath)'">true</_JalxamlUsesDefaultIntermediateOutputPath>
    <EnableDefaultJalxamlItems Condition="'$(EnableDefaultJalxamlItems)' == ''">true</EnableDefaultJalxamlItems>

    <!-- 默认启用优化 -->
    <EnableJalxamlOptimization Condition="'$(EnableJalxamlOptimization)' == ''">true</EnableJalxamlOptimization>

    <!-- Debug 配置下生成调试信息 -->
    <JalxamlDebugInfo Condition="'$(JalxamlDebugInfo)' == '' And '$(Configuration)' == 'Debug'">true</JalxamlDebugInfo>
    <JalxamlDebugInfo Condition="'$(JalxamlDebugInfo)' == ''">false</JalxamlDebugInfo>
    <EnableJalxamlRazorTransform Condition="'$(EnableJalxamlRazorTransform)' == ''">true</EnableJalxamlRazorTransform>
    <_JalxamlDefaultRazorIntermediateOutputPath Condition="'$(_JalxamlDefaultRazorIntermediateOutputPath)' == ''">$(JalxamlIntermediateOutputPath)Razor\</_JalxamlDefaultRazorIntermediateOutputPath>
    <JalxamlRazorIntermediateOutputPath Condition="'$(JalxamlRazorIntermediateOutputPath)' == ''">$(_JalxamlDefaultRazorIntermediateOutputPath)</JalxamlRazorIntermediateOutputPath>
    <_JalxamlUsesDefaultRazorIntermediateOutputPath Condition="'$(JalxamlRazorIntermediateOutputPath)' == '$(_JalxamlDefaultRazorIntermediateOutputPath)'">true</_JalxamlUsesDefaultRazorIntermediateOutputPath>

    <!-- HLSL 着色器预编译 -->
    <EnableHlslShaderPrecompilation Condition="'$(EnableHlslShaderPrecompilation)' == ''">false</EnableHlslShaderPrecompilation>
    <!-- 启用内置着色器预编译（从 Jalium.UI.Gpu 的 ShaderLibrary 提取并编译） -->
    <EnableBuiltInShaderPrecompilation Condition="'$(EnableBuiltInShaderPrecompilation)' == ''">false</EnableBuiltInShaderPrecompilation>
    <!-- 着色器编译器路径（fxc.exe 或 dxc.exe，留空自动检测） -->
    <HlslShaderCompilerPath Condition="'$(HlslShaderCompilerPath)' == ''"></HlslShaderCompilerPath>
    <!-- 着色器优化级别：0-3 -->
    <HlslShaderOptimizationLevel Condition="'$(HlslShaderOptimizationLevel)' == ''">3</HlslShaderOptimizationLevel>
    <!-- Debug 配置下着色器调试信息 -->
    <HlslShaderDebugInfo Condition="'$(HlslShaderDebugInfo)' == '' And '$(Configuration)' == 'Debug'">true</HlslShaderDebugInfo>
    <HlslShaderDebugInfo Condition="'$(HlslShaderDebugInfo)' == ''">false</HlslShaderDebugInfo>
    <!-- 着色器警告视为错误 -->
    <HlslShaderWarningsAsErrors Condition="'$(HlslShaderWarningsAsErrors)' == ''">true</HlslShaderWarningsAsErrors>
    <!-- 着色器中间输出路径 -->
    <HlslShaderIntermediateOutputPath Condition="'$(HlslShaderIntermediateOutputPath)' == ''">$(IntermediateOutputPath)Shaders\</HlslShaderIntermediateOutputPath>
  </PropertyGroup>

  <PropertyGroup>
    <DefaultItemExcludes>$(DefaultItemExcludes);$(JalxamlIntermediateOutputPath)**\*;$(JalxamlRazorIntermediateOutputPath)**\*;Jalxaml\**\*;Razor\**\*</DefaultItemExcludes>
  </PropertyGroup>

  <!-- 定义 JALXAML 文件类型的 Visual Studio 显示属性 -->
  <ItemDefinitionGroup>
    <JalxamlPage>
      <SubType>Designer</SubType>
    </JalxamlPage>
    <JalxamlApplicationDefinition>
      <SubType>Designer</SubType>
    </JalxamlApplicationDefinition>
    <HlslShader>
      <EntryPoint></EntryPoint>
      <ShaderModel></ShaderModel>
      <ShaderType></ShaderType>
    </HlslShader>
  </ItemDefinitionGroup>

  <!-- Visual Studio 属性页架构 - 定义 JalxamlPage 在属性窗口的显示 -->
  <ItemGroup>
    <PropertyPageSchema Include="$(MSBuildThisFileDirectory)Jalium.UI.Build.xml" />
  </ItemGroup>

  <!-- Provide core Jalium primitives without importing the full Jalium.UI namespace. -->
  <ItemGroup Condition="'$(DisableJaliumGlobalUsings)' != 'true' and '$(DisableJaliumPrimitiveAliases)' != 'true'">
    <Using Include="Jalium.UI.Thickness" Alias="Thickness" />
    <Using Include="Jalium.UI.CornerRadius" Alias="CornerRadius" />
  </ItemGroup>

</Project>
