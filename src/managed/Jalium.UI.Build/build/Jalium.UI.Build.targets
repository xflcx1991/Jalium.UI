<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Declare custom item types. -->
  <ItemGroup>
    <AvailableItemName Include="JalxamlPage" />
    <AvailableItemName Include="JalxamlApplicationDefinition" />
  </ItemGroup>

  <!-- Default task and compiler paths. -->
  <PropertyGroup>
    <_JalxamlTasksPath Condition="'$(_JalxamlTasksPath)' == ''">$(MSBuildThisFileDirectory)..\tasks\net10.0\Jalium.UI.Build.dll</_JalxamlTasksPath>
    <JalxamlCompilerPath Condition="'$(JalxamlCompilerPath)' == ''">$(MSBuildThisFileDirectory)..\tools\jalxamlc.exe</JalxamlCompilerPath>
    <EnableJalxamlOptimization Condition="'$(EnableJalxamlOptimization)' == ''">true</EnableJalxamlOptimization>
    <JalxamlDebugInfo Condition="'$(JalxamlDebugInfo)' == ''">false</JalxamlDebugInfo>
    <_JalxamlResolvedOutputConfigurationSegment Condition="'$(Configuration)' != ''">$(Configuration)\</_JalxamlResolvedOutputConfigurationSegment>
    <_JalxamlResolvedOutputTargetFrameworkSegment Condition="'$(TargetFramework)' != ''">$(TargetFramework)\</_JalxamlResolvedOutputTargetFrameworkSegment>
    <_JalxamlResolvedOutputRuntimeIdentifierSegment Condition="'$(RuntimeIdentifier)' != ''">$(RuntimeIdentifier)\</_JalxamlResolvedOutputRuntimeIdentifierSegment>
    <JalxamlIntermediateOutputPath Condition="'$(_JalxamlUsesDefaultIntermediateOutputPath)' == 'true'">$(MSBuildProjectExtensionsPath)$(_JalxamlResolvedOutputConfigurationSegment)$(_JalxamlResolvedOutputTargetFrameworkSegment)$(_JalxamlResolvedOutputRuntimeIdentifierSegment)Jalxaml\</JalxamlIntermediateOutputPath>
    <JalxamlIntermediateOutputPath Condition="'$(JalxamlIntermediateOutputPath)' == ''">$(MSBuildProjectExtensionsPath)$(_JalxamlResolvedOutputConfigurationSegment)$(_JalxamlResolvedOutputTargetFrameworkSegment)$(_JalxamlResolvedOutputRuntimeIdentifierSegment)Jalxaml\</JalxamlIntermediateOutputPath>
    <JalxamlRazorIntermediateOutputPath Condition="'$(_JalxamlUsesDefaultRazorIntermediateOutputPath)' == 'true'">$(JalxamlIntermediateOutputPath)Razor\</JalxamlRazorIntermediateOutputPath>
    <EnableJalxamlCodeGeneration Condition="'$(EnableJalxamlCodeGeneration)' == ''">true</EnableJalxamlCodeGeneration>
    <EnableJalxamlRazorTransform Condition="'$(EnableJalxamlRazorTransform)' == ''">true</EnableJalxamlRazorTransform>
  </PropertyGroup>

  <!-- Discover .jalxaml files by default. -->
  <ItemGroup Condition="'$(EnableDefaultJalxamlItems)' != 'false'">
    <JalxamlPage Include="**\*.jalxaml" Exclude="$(DefaultItemExcludes);$(DefaultExcludesInProjectFolder)" />
  </ItemGroup>

  <!-- Nest .jalxaml.cs files under the matching .jalxaml file in Solution Explorer. -->
  <ItemGroup>
    <Compile Update="**\*.jalxaml.cs" DependentUpon="%(Filename)" />
  </ItemGroup>

  <!-- Load custom build tasks. -->
  <UsingTask TaskName="Jalium.UI.Build.CompileJalxamlTask" AssemblyFile="$(_JalxamlTasksPath)" />
  <UsingTask TaskName="Jalium.UI.Build.GenerateJalxamlCodeBehindTask" AssemblyFile="$(_JalxamlTasksPath)" />
  <UsingTask TaskName="Jalium.UI.Build.TransformJalxamlRazorTask" AssemblyFile="$(_JalxamlTasksPath)" />
  <UsingTask TaskName="Jalium.UI.Build.CompileHlslShadersTask" AssemblyFile="$(_JalxamlTasksPath)" />
  <UsingTask TaskName="Jalium.UI.Build.ExtractHlslShadersTask" AssemblyFile="$(_JalxamlTasksPath)" />

  <!-- Remove duplicate source generator analyzers when a local ProjectReference is also present. -->
  <Target Name="DeduplicateJalxamlSourceGenerator"
          BeforeTargets="CoreCompile"
          Condition="'$(EnableJalxamlCodeGeneration)' == 'false'">
    <ItemGroup>
      <_JalxamlSourceGeneratorAnalyzer Include="@(Analyzer)"
                                       Condition="'%(Filename)' == 'Jalium.UI.Xaml.SourceGenerator'" />
      <_NonNugetJalxamlSourceGeneratorAnalyzer Include="@(_JalxamlSourceGeneratorAnalyzer)"
                                               Condition="!$([System.String]::new('%(FullPath)').Contains('.nuget'))" />
      <Analyzer Remove="@(Analyzer)"
                Condition="'%(Filename)' == 'Jalium.UI.Xaml.SourceGenerator'
                           AND $([System.String]::new('%(FullPath)').Contains('.nuget'))
                           AND '@(_NonNugetJalxamlSourceGeneratorAnalyzer)' != ''" />
    </ItemGroup>
  </Target>

  <Target Name="FilterGeneratedJalxamlInputs"
          BeforeTargets="PrepareJalxamlForSourceGenerator;TransformJalxamlRazor;GenerateJalxamlCodeBehind;CompileJalxaml;EmbedJalxamlSources"
          Condition="'@(JalxamlPage)' != '' or '@(JalxamlApplicationDefinition)' != ''">
    <PropertyGroup>
      <_JalxamlIntermediateOutputFullPath>$([System.IO.Path]::GetFullPath('$(JalxamlIntermediateOutputPath)'))</_JalxamlIntermediateOutputFullPath>
      <_JalxamlRazorIntermediateOutputFullPath>$([System.IO.Path]::GetFullPath('$(JalxamlRazorIntermediateOutputPath)'))</_JalxamlRazorIntermediateOutputFullPath>
      <_LegacyJalxamlRazorOutputFullPath>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\Razor\'))</_LegacyJalxamlRazorOutputFullPath>
    </PropertyGroup>

    <ItemGroup>
      <_GeneratedJalxamlPage Include="@(JalxamlPage)"
                             Condition="'%(DefiningProjectName)' == 'Jalium.UI.Build' and ($([System.String]::new('%(FullPath)').StartsWith('$(_JalxamlIntermediateOutputFullPath)')) or $([System.String]::new('%(FullPath)').StartsWith('$(_JalxamlRazorIntermediateOutputFullPath)')) or $([System.String]::new('%(FullPath)').StartsWith('$(_LegacyJalxamlRazorOutputFullPath)')))" />
      <_GeneratedJalxamlApplicationDefinition Include="@(JalxamlApplicationDefinition)"
                                              Condition="'%(DefiningProjectName)' == 'Jalium.UI.Build' and ($([System.String]::new('%(FullPath)').StartsWith('$(_JalxamlIntermediateOutputFullPath)')) or $([System.String]::new('%(FullPath)').StartsWith('$(_JalxamlRazorIntermediateOutputFullPath)')) or $([System.String]::new('%(FullPath)').StartsWith('$(_LegacyJalxamlRazorOutputFullPath)')))" />
      <JalxamlPage Remove="@(_GeneratedJalxamlPage)" />
      <JalxamlApplicationDefinition Remove="@(_GeneratedJalxamlApplicationDefinition)" />
    </ItemGroup>

    <Message Condition="'@(_GeneratedJalxamlPage)' != '' or '@(_GeneratedJalxamlApplicationDefinition)' != ''"
             Text="Ignored generated JALXAML inputs: @(_GeneratedJalxamlPage);@(_GeneratedJalxamlApplicationDefinition)"
             Importance="low" />
  </Target>

  <!-- Register source files for the source generator. -->
  <Target Name="PrepareJalxamlForSourceGenerator"
          BeforeTargets="CoreCompile"
          DependsOnTargets="ResolveEffectiveJalxamlSources"
          Condition="'$(EnableJalxamlCodeGeneration)' == 'false' and ('@(JalxamlPage)' != '' or '@(JalxamlApplicationDefinition)' != '')">
    <ItemGroup>
      <AdditionalFiles Include="@(_EffectiveJalxamlSources)" />
      <AdditionalFiles Include="$(JalxamlIntermediateOutputPath)*.uic.base64" />
    </ItemGroup>
    <Message Text="Added JALXAML files to AdditionalFiles for the source generator." Importance="low" />
  </Target>

  <!-- Transform Razor-style JALXAML before compilation and embedding. -->
  <Target Name="TransformJalxamlRazor"
          BeforeTargets="CompileJalxaml;EmbedJalxamlSources"
          DependsOnTargets="PrepareForBuild;ResolveAssemblyReferences"
          Inputs="@(JalxamlPage);@(JalxamlApplicationDefinition)"
          Outputs="@(JalxamlPage->'$(JalxamlRazorIntermediateOutputPath)%(RecursiveDir)%(Filename)%(Extension)');@(JalxamlApplicationDefinition->'$(JalxamlRazorIntermediateOutputPath)%(RecursiveDir)%(Filename)%(Extension)');$(JalxamlRazorIntermediateOutputPath)Jalxaml.RazorMetadata.g.cs"
          Condition="'$(EnableJalxamlRazorTransform)' == 'true' and ('@(JalxamlPage)' != '' or '@(JalxamlApplicationDefinition)' != '')">

    <MakeDir Directories="$(JalxamlRazorIntermediateOutputPath)" />

    <TransformJalxamlRazorTask
        SourceFiles="@(JalxamlPage);@(JalxamlApplicationDefinition)"
        OutputDirectory="$(JalxamlRazorIntermediateOutputPath)"
        ProjectDirectory="$(MSBuildProjectDirectory)"
        ReferencePaths="@(ReferencePath)">
      <Output TaskParameter="TransformedFiles" ItemName="_JalxamlRazorTransformedFiles" />
      <Output TaskParameter="GeneratedCodeFiles" ItemName="_JalxamlRazorGeneratedCodeFiles" />
    </TransformJalxamlRazorTask>

    <ItemGroup>
      <FileWrites Include="@(_JalxamlRazorTransformedFiles)" />
      <FileWrites Include="@(_JalxamlRazorGeneratedCodeFiles)" />
    </ItemGroup>

    <Message Text="Transformed JALXAML Razor sources: @(_JalxamlRazorTransformedFiles)" Importance="normal" />
    <Message Condition="'@(_JalxamlRazorGeneratedCodeFiles)' != ''"
             Text="Generated JALXAML Razor metadata code: @(_JalxamlRazorGeneratedCodeFiles)" Importance="normal" />
  </Target>

  <!-- Choose the final source set used by downstream targets. -->
  <Target Name="ResolveEffectiveJalxamlSources"
          DependsOnTargets="TransformJalxamlRazor"
          Condition="'@(JalxamlPage)' != '' or '@(JalxamlApplicationDefinition)' != ''">
    <ItemGroup>
      <_EffectiveJalxamlSources Remove="@(_EffectiveJalxamlSources)" />
      <_EffectiveJalxamlSources Include="@(_JalxamlRazorTransformedFiles)"
                                Condition="'$(EnableJalxamlRazorTransform)' == 'true' and '@(_JalxamlRazorTransformedFiles)' != ''" />
      <_EffectiveJalxamlSources Include="@(JalxamlPage);@(JalxamlApplicationDefinition)"
                                Condition="'@(_EffectiveJalxamlSources)' == ''">
        <RazorRelativeLogicalPath></RazorRelativeLogicalPath>
      </_EffectiveJalxamlSources>
    </ItemGroup>
  </Target>

  <!-- Include Razor-generated code in the compile set. -->
  <Target Name="IncludeJalxamlRazorGeneratedCode"
          BeforeTargets="CoreCompile"
          DependsOnTargets="TransformJalxamlRazor"
          Condition="'$(EnableJalxamlRazorTransform)' == 'true'">
    <ItemGroup>
      <Compile Remove="@(_JalxamlRazorGeneratedCodeFiles)" />
      <Compile Include="@(_JalxamlRazorGeneratedCodeFiles)" Condition="Exists('%(Identity)')" />
      <!-- Always include the metadata file even when TransformJalxamlRazor was skipped (incremental build) -->
      <Compile Remove="$(JalxamlRazorIntermediateOutputPath)Jalxaml.RazorMetadata.g.cs" />
      <Compile Include="$(JalxamlRazorIntermediateOutputPath)Jalxaml.RazorMetadata.g.cs" Condition="Exists('$(JalxamlRazorIntermediateOutputPath)Jalxaml.RazorMetadata.g.cs')" />
      <FileWrites Include="@(_JalxamlRazorGeneratedCodeFiles)" Condition="Exists('%(Identity)')" />
    </ItemGroup>
  </Target>

  <!-- Generate code-behind files when the source generator is disabled. -->
  <Target Name="GenerateJalxamlCodeBehind"
          BeforeTargets="CoreCompile"
          DependsOnTargets="PrepareForBuild;ResolveEffectiveJalxamlSources"
          Inputs="@(JalxamlPage);@(JalxamlApplicationDefinition)"
          Outputs="@(JalxamlPage->'$(JalxamlIntermediateOutputPath)%(Filename).g.cs');@(JalxamlApplicationDefinition->'$(JalxamlIntermediateOutputPath)%(Filename).g.cs');$(JalxamlIntermediateOutputPath)Jalxaml.ViewAliases.g.cs"
          Condition="'$(EnableJalxamlCodeGeneration)' == 'true' and ('@(JalxamlPage)' != '' or '@(JalxamlApplicationDefinition)' != '')">

    <MakeDir Directories="$(JalxamlIntermediateOutputPath)" />

    <GenerateJalxamlCodeBehindTask
        SourceFiles="@(_EffectiveJalxamlSources)"
        OutputDirectory="$(JalxamlIntermediateOutputPath)"
        RootNamespace="$(RootNamespace)"
        CompilerPath="$(JalxamlCompilerPath)"
        ProjectDirectory="$(MSBuildProjectDirectory)">
      <Output TaskParameter="GeneratedFiles" ItemName="_JalxamlGeneratedFiles" />
    </GenerateJalxamlCodeBehindTask>

    <ItemGroup>
      <Compile Include="@(_JalxamlGeneratedFiles)" />
      <FileWrites Include="@(_JalxamlGeneratedFiles)" />
    </ItemGroup>

    <Message Text="Generated JALXAML code-behind files: @(_JalxamlGeneratedFiles)" Importance="normal" />
  </Target>

  <!-- Always register expected generated files, even when generation is skipped incrementally. -->
  <Target Name="IncludeJalxamlGeneratedCodeBehind"
          BeforeTargets="CoreCompile"
          DependsOnTargets="GenerateJalxamlCodeBehind"
          Condition="'$(EnableJalxamlCodeGeneration)' == 'true' and ('@(JalxamlPage)' != '' or '@(JalxamlApplicationDefinition)' != '')">
    <ItemGroup>
      <_ExpectedJalxamlGeneratedFiles Include="@(JalxamlPage->'$(JalxamlIntermediateOutputPath)%(Filename).g.cs')" />
      <_ExpectedJalxamlGeneratedFiles Include="@(JalxamlApplicationDefinition->'$(JalxamlIntermediateOutputPath)%(Filename).g.cs')" />
      <_ExpectedJalxamlGeneratedFiles Include="$(JalxamlIntermediateOutputPath)Jalxaml.ViewAliases.g.cs" />
      <Compile Remove="@(_ExpectedJalxamlGeneratedFiles)" />
      <Compile Include="@(_ExpectedJalxamlGeneratedFiles)" Condition="Exists('%(Identity)')" />
      <FileWrites Include="@(_ExpectedJalxamlGeneratedFiles)" Condition="Exists('%(Identity)')" />
    </ItemGroup>
  </Target>

  <!-- Compile JALXAML sources to .uic files. -->
  <Target Name="CompileJalxaml"
          BeforeTargets="PrepareResources;BeforeBuild;CoreCompile"
          DependsOnTargets="PrepareForBuild;ResolveEffectiveJalxamlSources"
          Inputs="@(_EffectiveJalxamlSources)"
          Outputs="$(JalxamlIntermediateOutputPath)%(Filename).uic"
          Condition="'@(JalxamlPage)' != '' or '@(JalxamlApplicationDefinition)' != ''">

    <CompileJalxamlTask
        SourceFiles="@(_EffectiveJalxamlSources)"
        OutputDirectory="$(JalxamlIntermediateOutputPath)"
        ProjectDirectory="$(MSBuildProjectDirectory)"
        IntermediateOutputPath="$(JalxamlIntermediateOutputPath)"
        EnableOptimization="$(EnableJalxamlOptimization)"
        GenerateDebugInfo="$(JalxamlDebugInfo)"
        CompilerPath="$(JalxamlCompilerPath)">
      <Output TaskParameter="CompiledFiles" ItemName="_CompiledJalxamlFiles" />
    </CompileJalxamlTask>

    <ItemGroup>
      <FileWrites Include="@(_CompiledJalxamlFiles)" />
      <FileWrites Include="@(_CompiledJalxamlFiles->'%(Identity).base64')" />
    </ItemGroup>

    <ItemGroup Condition="'$(EnableJalxamlCodeGeneration)' == 'false'">
      <AdditionalFiles Include="@(_CompiledJalxamlFiles->'%(Identity).base64')">
        <SourceJalxaml>%(Identity)</SourceJalxaml>
      </AdditionalFiles>
    </ItemGroup>

    <Message Text="Compiled JALXAML sources: @(_CompiledJalxamlFiles)" Importance="normal" />
  </Target>

  <!-- Embed compiled .uic files as resources. -->
  <Target Name="EmbedCompiledJalxaml"
          BeforeTargets="AssignTargetPaths;PrepareResources"
          DependsOnTargets="CompileJalxaml"
          Condition="'@(JalxamlPage)' != '' or '@(JalxamlApplicationDefinition)' != ''">

    <ItemGroup>
      <_UicFilesToEmbed Include="$(JalxamlIntermediateOutputPath)*.uic" />
    </ItemGroup>

    <ItemGroup>
      <EmbeddedResource Include="@(_UicFilesToEmbed)">
        <LogicalName>$(RootNamespace).%(Filename).uic</LogicalName>
      </EmbeddedResource>
    </ItemGroup>

    <Message Text="Embedded compiled JALXAML resources: @(_UicFilesToEmbed -> '$(RootNamespace).%(Filename).uic')" Importance="normal" />
  </Target>

  <!-- Embed original JALXAML sources for runtime XAML parsing. -->
  <Target Name="EmbedJalxamlSources"
          BeforeTargets="AssignTargetPaths;CoreCompile"
          DependsOnTargets="ResolveEffectiveJalxamlSources"
          Condition="'@(JalxamlPage)' != '' or '@(JalxamlApplicationDefinition)' != ''">

    <ItemGroup>
      <_JalxamlSourcesToEmbed Include="@(_EffectiveJalxamlSources)">
        <JalxamlLogicalName Condition="'%(_EffectiveJalxamlSources.RazorRelativeLogicalPath)' != ''">$(RootNamespace).%(_EffectiveJalxamlSources.RazorRelativeLogicalPath).jalxaml</JalxamlLogicalName>
        <JalxamlLogicalName Condition="'%(_EffectiveJalxamlSources.RazorRelativeLogicalPath)' == ''">$(RootNamespace).$([System.String]::Copy('%(_EffectiveJalxamlSources.RelativeDir)%(_EffectiveJalxamlSources.Filename)').Replace('\','.').Replace('/','.').TrimStart('.')).jalxaml</JalxamlLogicalName>
      </_JalxamlSourcesToEmbed>
      <EmbeddedResource Include="@(_JalxamlSourcesToEmbed)">
        <ManifestResourceName>%(_JalxamlSourcesToEmbed.JalxamlLogicalName)</ManifestResourceName>
        <LogicalName>%(_JalxamlSourcesToEmbed.JalxamlLogicalName)</LogicalName>
      </EmbeddedResource>
    </ItemGroup>

    <Message Text="Embedded original JALXAML sources: @(_EffectiveJalxamlSources)" Importance="normal" />
  </Target>

  <!--
    Embed `<Resource>` items as manifest resources so BitmapImage / ImageSource
    relative URIs (e.g. `Assets/Templates/desktop.png`) can be resolved at
    runtime via Assembly.GetManifestResourceStream — see
    Jalium.UI.Media.ImageSource.BitmapImage.LoadFromUri.

    Why a custom target: SDK-style projects do NOT recognise the WPF-flavoured
    `<Resource>` ItemGroup unless they enable `<UseWPF>true</UseWPF>`, which
    pulls in the entire WPF SDK (and only works on net*-windows TFMs).  Jalium
    is a cross-platform UI framework that targets bare `net10.0`, so we
    re-implement the embedding step ourselves with a shape that matches how
    JALXAML sources are embedded above (see EmbedJalxamlSources): the logical
    name is `<RootNamespace>.<sanitised-relative-path>` so `Assets\Templates\
    desktop.png` becomes `<RootNamespace>.Assets.Templates.desktop.png`.
    BitmapImage's relative-URI loader generates the same candidate name when
    looking up a resource, which keeps consumer XAML / code-behind free of
    assembly-prefix bookkeeping.

    The `<Resource>` items are removed afterwards because the SDK has no
    built-in target that consumes them — leaving them in place would just be
    dead metadata in the final project.
  -->
  <Target Name="EmbedJaliumResourceItems"
          BeforeTargets="AssignTargetPaths;PrepareResources;CoreCompile"
          Condition="'@(Resource)' != ''">

    <ItemGroup>
      <_JaliumResourceToEmbed Include="@(Resource)">
        <JaliumResourceLogicalName>$(RootNamespace).$([System.String]::Copy('%(Resource.RelativeDir)%(Resource.Filename)%(Resource.Extension)').Replace('\','.').Replace('/','.').TrimStart('.'))</JaliumResourceLogicalName>
      </_JaliumResourceToEmbed>
      <EmbeddedResource Include="@(_JaliumResourceToEmbed)">
        <ManifestResourceName>%(_JaliumResourceToEmbed.JaliumResourceLogicalName)</ManifestResourceName>
        <LogicalName>%(_JaliumResourceToEmbed.JaliumResourceLogicalName)</LogicalName>
      </EmbeddedResource>
      <Resource Remove="@(Resource)" />
    </ItemGroup>

    <Message Text="Embedded Resource items as manifest resources: @(_JaliumResourceToEmbed -> '%(JaliumResourceLogicalName)')"
             Importance="normal" />
  </Target>

  <!-- Compile project-defined HLSL shaders. -->
  <Target Name="CompileHlslShaders"
          BeforeTargets="PrepareResources;CoreCompile"
          DependsOnTargets="PrepareForBuild;ResolveAssemblyReferences"
          Inputs="@(HlslShader)"
          Outputs="$(HlslShaderIntermediateOutputPath)%(HlslShader.ShaderType).cso"
          Condition="'$(EnableHlslShaderPrecompilation)' == 'true' and '@(HlslShader)' != ''">

    <MakeDir Directories="$(HlslShaderIntermediateOutputPath)" />

    <CompileHlslShadersTask
        SourceFiles="@(HlslShader)"
        OutputDirectory="$(HlslShaderIntermediateOutputPath)"
        ShaderCompilerPath="$(HlslShaderCompilerPath)"
        OptimizationLevel="$(HlslShaderOptimizationLevel)"
        EnableDebugInfo="$(HlslShaderDebugInfo)"
        WarningsAsErrors="$(HlslShaderWarningsAsErrors)">
      <Output TaskParameter="CompiledShaders" ItemName="_CompiledHlslShaders" />
    </CompileHlslShadersTask>

    <ItemGroup>
      <FileWrites Include="@(_CompiledHlslShaders)" />
    </ItemGroup>

    <Message Text="Compiled HLSL shaders: @(_CompiledHlslShaders)" Importance="normal" />
  </Target>

  <!-- Extract built-in HLSL shaders from Jalium.UI.Gpu when enabled. -->
  <Target Name="ExtractBuiltInHlslShaders"
          BeforeTargets="CompileHlslShaders"
          DependsOnTargets="ResolveAssemblyReferences"
          Condition="'$(EnableBuiltInShaderPrecompilation)' == 'true' and '$(EnableHlslShaderPrecompilation)' == 'true'">

    <MakeDir Directories="$(HlslShaderIntermediateOutputPath)" />

    <PropertyGroup>
      <_GpuAssemblyPath>@(ReferencePath->WithMetadataValue('NuGetPackageId','Jalium.UI.Gpu')->'%(Identity)')</_GpuAssemblyPath>
      <_GpuAssemblyPath Condition="'$(_GpuAssemblyPath)' == ''">@(ReferencePath->WithMetadataValue('Filename','Jalium.UI.Gpu')->'%(Identity)')</_GpuAssemblyPath>
    </PropertyGroup>

    <ExtractHlslShadersTask
        Condition="'$(_GpuAssemblyPath)' != ''"
        GpuAssemblyPath="$(_GpuAssemblyPath)"
        OutputDirectory="$(HlslShaderIntermediateOutputPath)">
      <Output TaskParameter="ExtractedShaders" ItemName="HlslShader" />
    </ExtractHlslShadersTask>

    <Message Condition="'$(_GpuAssemblyPath)' != ''"
             Text="Extracted built-in HLSL shaders to $(HlslShaderIntermediateOutputPath)" Importance="normal" />
    <Message Condition="'$(_GpuAssemblyPath)' == ''"
             Text="Skipped built-in HLSL shader extraction because Jalium.UI.Gpu was not resolved." Importance="normal" />
  </Target>

  <!-- Embed compiled shader blobs as resources. -->
  <Target Name="EmbedCompiledShaders"
          BeforeTargets="AssignTargetPaths;PrepareResources"
          DependsOnTargets="CompileHlslShaders"
          Condition="'$(EnableHlslShaderPrecompilation)' == 'true'">

    <ItemGroup>
      <_CsoFilesToEmbed Include="$(HlslShaderIntermediateOutputPath)*.cso" />
    </ItemGroup>

    <ItemGroup>
      <EmbeddedResource Include="@(_CsoFilesToEmbed)">
        <LogicalName>$(RootNamespace).Shaders.%(Filename).cso</LogicalName>
      </EmbeddedResource>
    </ItemGroup>

    <Message Condition="'@(_CsoFilesToEmbed)' != ''"
             Text="Embedded compiled shaders: @(_CsoFilesToEmbed -> '$(RootNamespace).Shaders.%(Filename).cso')" Importance="normal" />
  </Target>

  <!-- Remove generated artifacts on Clean. -->
  <Target Name="CleanJalxaml" AfterTargets="Clean">
    <Delete Files="$(JalxamlIntermediateOutputPath)**\*.g.cs" />
    <Delete Files="$(JalxamlIntermediateOutputPath)**\*.uic" />
    <Delete Files="$(JalxamlRazorIntermediateOutputPath)**\*.jalxaml" />
    <Delete Files="$(JalxamlRazorIntermediateOutputPath)**\*.g.cs" />
    <Delete Files="$(HlslShaderIntermediateOutputPath)**\*.cso" />
    <Delete Files="$(HlslShaderIntermediateOutputPath)**\*.hlsl" />
    <RemoveDir Directories="$(JalxamlIntermediateOutputPath)" />
    <RemoveDir Directories="$(JalxamlRazorIntermediateOutputPath)" />
    <RemoveDir Directories="$(HlslShaderIntermediateOutputPath)" />
  </Target>

  <!--
    NativeAOT single-exe configuration entry point.

    Consumer enables it with:
        <PublishAot>true</PublishAot>
        <UseJaliumNativeAot>true</UseJaliumNativeAot>

    What this target wires up:
      - Static archive resolution: prefers $(JaliumNativeAotAssetRoot)$(RuntimeIdentifier)\,
        falling back to the in-repo build output for source-tree consumers.
      - DirectPInvoke + NativeLibrary for every Jalium native module
        (core / d3d12 / software / platform + aggregator) plus optional browser.
      - LinkerArg for every Win32 / DirectX system import that the static
        archives depend on (gdi32 etc. — NativeAOT does NOT auto-link these).
      - StripJaliumNativeDllsAfterPublish: removes the shared-DLL drop-ins that
        Interop's Content / build-time targets copy by default, so the publish
        folder really is a single self-contained exe.

    Knobs:
      <JaliumIncludeBrowserAot>true|false</JaliumIncludeBrowserAot>
          default false. Set true to include WebView2 browser support — note
          this requires WebView2Loader.dll alongside the exe (browser is not
          a true single-exe scenario).
  -->
  <Target Name="ConfigureJaliumNativeAot"
          BeforeTargets="SetupOSSpecificProps"
          Condition="'$(UseJaliumNativeAot)' == 'true'">
    <PropertyGroup>
      <_JaliumNativeAotAssetDirectory>$([System.IO.Path]::GetFullPath('$(JaliumNativeAotAssetRoot)$(RuntimeIdentifier)\'))</_JaliumNativeAotAssetDirectory>
      <!-- In-repo / source-tree fallback paths -->
      <_JaliumNativeAotFallbackAssetDirectory>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\..\native\bin\native-static\Release\'))</_JaliumNativeAotFallbackAssetDirectory>
      <_JaliumNativeAotPackagedAssetDirectory>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)nativeaot\$(RuntimeIdentifier)\'))</_JaliumNativeAotPackagedAssetDirectory>
      <!-- When the package was restored from NuGet, archives live in build/nativeaot/<rid>/ -->
      <_JaliumNativeAotAssetDirectory Condition="'$(RuntimeIdentifier)' == 'win-x64' and !Exists('$(_JaliumNativeAotAssetDirectory)jalium.native.core.static.lib') and Exists('$(_JaliumNativeAotPackagedAssetDirectory)jalium.native.core.static.lib')">$(_JaliumNativeAotPackagedAssetDirectory)</_JaliumNativeAotAssetDirectory>
      <!-- Source-tree fallback (when consumed via ProjectReference inside the repo) -->
      <_JaliumNativeAotAssetDirectory Condition="'$(RuntimeIdentifier)' == 'win-x64' and !Exists('$(_JaliumNativeAotAssetDirectory)jalium.native.core.static.lib') and Exists('$(_JaliumNativeAotFallbackAssetDirectory)jalium.native.core.static.lib')">$(_JaliumNativeAotFallbackAssetDirectory)</_JaliumNativeAotAssetDirectory>

      <JaliumIncludeBrowserAot Condition="'$(JaliumIncludeBrowserAot)' == ''">false</JaliumIncludeBrowserAot>
      <!-- Opt-in: include the Vulkan rendering backend in the AOT image alongside D3D12.
           When enabled, jalium.native.vulkan.static.lib is linked, vulkan-1.lib (the
           Vulkan loader import library, shipped with the Vulkan SDK) must be on the
           linker's lib search path, and at runtime the managed-side NativeMethods
           static ctor will invoke jalium_vulkan_init() so RenderBackend.Vulkan
           becomes selectable.
           Default off — most Windows AOT consumers ship D3D12-only and don't want
           a hard dependency on the Vulkan SDK at link time. -->
      <JaliumIncludeVulkanAot Condition="'$(JaliumIncludeVulkanAot)' == ''">false</JaliumIncludeVulkanAot>

      <!-- WebView2LoaderStatic.lib resolution: prefer the copy shipped inside
           Jalium.UI.Build's package, fall back to the source-tree third_party
           copy for in-repo consumers. -->
      <_JaliumWebView2LoaderStaticLib Condition="'$(JaliumIncludeBrowserAot)' == 'true' and Exists('$(_JaliumNativeAotAssetDirectory)WebView2LoaderStatic.lib')">$(_JaliumNativeAotAssetDirectory)WebView2LoaderStatic.lib</_JaliumWebView2LoaderStaticLib>
      <_JaliumWebView2LoaderStaticLib Condition="'$(JaliumIncludeBrowserAot)' == 'true' and '$(_JaliumWebView2LoaderStaticLib)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\..\native\jalium.native.browser\third_party\webview2\lib\x64\WebView2LoaderStatic.lib'))</_JaliumWebView2LoaderStaticLib>
    </PropertyGroup>

    <Error Condition="'$(JaliumIncludeBrowserAot)' == 'true' and ('$(_JaliumWebView2LoaderStaticLib)' == '' or !Exists('$(_JaliumWebView2LoaderStaticLib)'))"
           Text="JaliumIncludeBrowserAot=true requires WebView2LoaderStatic.lib. Looked at '$(_JaliumNativeAotAssetDirectory)WebView2LoaderStatic.lib' and the source-tree third_party fallback. Restore the Jalium.UI.Build NuGet package or copy WebView2LoaderStatic.lib (from Microsoft.Web.WebView2 NuGet) into src/native/jalium.native.browser/third_party/webview2/lib/x64/." />

    <Error Condition="'$(RuntimeIdentifier)' == ''"
           Text="UseJaliumNativeAot requires a RuntimeIdentifier. Set RuntimeIdentifier to a runtime with available static assets before publishing." />
    <Error Condition="'$(PublishAot)' != 'true'"
           Text="UseJaliumNativeAot requires PublishAot=true." />
    <Error Condition="!Exists('$(_JaliumNativeAotAssetDirectory)jalium.native.core.static.lib')"
           Text="Jalium NativeAOT static assets not found at '$(_JaliumNativeAotAssetDirectory)'. Restore the Jalium.UI.Build package, or build src/native/Jalium.Native.sln (Configuration=Release Platform=x64) for in-source consumers." />
    <Error Condition="!Exists('$(_JaliumNativeAotAssetDirectory)jalium.native.aot.static.lib')"
           Text="Missing jalium.native.aot.static.lib at '$(_JaliumNativeAotAssetDirectory)'. The package is older than the AOT-aware Jalium.UI.Build — bump Jalium.UI.Build to a version that ships the aggregator archive." />
    <Error Condition="'$(JaliumIncludeVulkanAot)' == 'true' and !Exists('$(_JaliumNativeAotAssetDirectory)jalium.native.vulkan.static.lib')"
           Text="JaliumIncludeVulkanAot=true requires jalium.native.vulkan.static.lib at '$(_JaliumNativeAotAssetDirectory)'. Build the Vulkan static archive (samples\build-native-static.ps1) or restore a Jalium.UI.Build package that ships it." />

    <ItemGroup>
      <!-- Managed-side P/Invoke hooks. The strings here MUST match the DLL
           names that appear in [LibraryImport] / [DllImport] sites. -->
      <DirectPInvoke Include="jalium.native.aot" />
      <DirectPInvoke Include="jalium.native.core" />
      <DirectPInvoke Include="jalium.native.d3d12" />
      <DirectPInvoke Include="jalium.native.software" />
      <DirectPInvoke Include="jalium.native.platform" />
      <DirectPInvoke Include="jalium.native.browser" Condition="'$(JaliumIncludeBrowserAot)' == 'true'" />
      <!-- NativeMethods.cs's static ctor P/Invokes VulkanInit; registering the import
           lets ILC resolve it as a direct static-symbol call instead of LoadLibrary. -->
      <DirectPInvoke Include="jalium.native.vulkan" Condition="'$(JaliumIncludeVulkanAot)' == 'true'" />
      <!-- NativeMediaInterop's [LibraryImport("jalium.native.media")] resolves to
           jalium_media_* symbols that the linker pulls from media.windows.static.lib. -->
      <DirectPInvoke Include="jalium.native.media" />

      <!-- Static archives. Order matters loosely: aggregator first so the
           linker sees its strong references to per-backend init functions
           before scanning the per-backend archives. -->
      <NativeLibrary Include="$(_JaliumNativeAotAssetDirectory)jalium.native.aot.static.lib" />
      <NativeLibrary Include="$(_JaliumNativeAotAssetDirectory)jalium.native.d3d12.static.lib" />
      <!-- Vulkan static archive — only linked when JaliumIncludeVulkanAot=true.
           Order vs d3d12 doesn't matter because both expose disjoint *_init symbol
           sets and managed RenderBackendSelector picks one at runtime. -->
      <NativeLibrary Include="$(_JaliumNativeAotAssetDirectory)jalium.native.vulkan.static.lib"
                     Condition="'$(JaliumIncludeVulkanAot)' == 'true'" />
      <NativeLibrary Include="$(_JaliumNativeAotAssetDirectory)jalium.native.software.static.lib" />
      <NativeLibrary Include="$(_JaliumNativeAotAssetDirectory)jalium.native.platform.static.lib" />
      <NativeLibrary Include="$(_JaliumNativeAotAssetDirectory)jalium.native.core.static.lib" />
      <!-- Media archives — must come AFTER the aggregator (whose strong references
           to jalium_media_initialize/shutdown/supported_video_codecs are what tells
           the linker to pull these in). The .core archive holds the cross-platform
           status helpers; .windows holds the WIC + Media Foundation implementations. -->
      <NativeLibrary Include="$(_JaliumNativeAotAssetDirectory)jalium.native.media.windows.static.lib"
                     Condition="Exists('$(_JaliumNativeAotAssetDirectory)jalium.native.media.windows.static.lib')" />
      <NativeLibrary Include="$(_JaliumNativeAotAssetDirectory)jalium.native.media.core.static.lib"
                     Condition="Exists('$(_JaliumNativeAotAssetDirectory)jalium.native.media.core.static.lib')" />
      <NativeLibrary Include="$(_JaliumNativeAotAssetDirectory)jalium.native.browser.static.lib"
                     Condition="'$(JaliumIncludeBrowserAot)' == 'true'" />
      <!-- WebView2LoaderStatic.lib is the in-process WebView2 loader: it
           locates the user-installed Edge WebView2 Runtime through COM/RoGet
           rather than via WebView2Loader.dll. browser.cpp under JALIUM_STATIC
           calls CreateCoreWebView2EnvironmentWithOptions /
           GetAvailableCoreWebView2BrowserVersionString as direct imports,
           which this archive resolves at link time. -->
      <NativeLibrary Include="$(_JaliumWebView2LoaderStaticLib)"
                     Condition="'$(JaliumIncludeBrowserAot)' == 'true'" />

      <!-- Win32 / DirectX system imports. NativeAOT only auto-links the .NET
           runtime's required set, so anything used by our static archives must
           be listed explicitly. Mirrors the AdditionalDependencies of the
           dynamic-DLL vcxproj projects. -->
      <NativeLibrary Include="d3d12.lib" />
      <NativeLibrary Include="dxgi.lib" />
      <NativeLibrary Include="dxguid.lib" />
      <NativeLibrary Include="d3dcompiler.lib" />
      <NativeLibrary Include="dwrite.lib" />
      <NativeLibrary Include="d2d1.lib" />
      <NativeLibrary Include="d3d11.lib" />
      <NativeLibrary Include="dcomp.lib" />
      <!-- GDI / windowing pulled by d3d12 desktop capture, glyph rasterizer,
           software GDI text path, and platform window/eventloop. -->
      <NativeLibrary Include="gdi32.lib" />
      <NativeLibrary Include="user32.lib" />
      <NativeLibrary Include="kernel32.lib" />
      <NativeLibrary Include="ole32.lib" />
      <NativeLibrary Include="oleaut32.lib" />
      <NativeLibrary Include="shcore.lib" />
      <NativeLibrary Include="shell32.lib" />
      <NativeLibrary Include="advapi32.lib" />
      <NativeLibrary Include="uuid.lib" />
      <NativeLibrary Include="dwmapi.lib" />
      <NativeLibrary Include="imm32.lib" />
      <NativeLibrary Include="winmm.lib" />
      <NativeLibrary Include="propsys.lib" />
      <!-- Media Foundation + WIC — required by jalium.native.media.windows.static.lib.
           Mirrors the AdditionalDependencies of the dynamic media.windows.vcxproj. -->
      <NativeLibrary Include="windowscodecs.lib" />
      <NativeLibrary Include="mfplat.lib" />
      <NativeLibrary Include="mfreadwrite.lib" />
      <NativeLibrary Include="mf.lib" />
      <NativeLibrary Include="mfuuid.lib" />
      <NativeLibrary Include="shlwapi.lib" />
      <!-- Vulkan loader (vulkan-1.dll) import library. Ships with the LunarG Vulkan SDK
           or VS Vulkan workload; consumers enabling JaliumIncludeVulkanAot must have
           it on the linker's lib search path. -->
      <NativeLibrary Include="vulkan-1.lib" Condition="'$(JaliumIncludeVulkanAot)' == 'true'" />
    </ItemGroup>
  </Target>

  <!--
    Strip post-publish artifacts that contradict the single-exe goal.

    Even with UseJaliumNativeAot=true, the Jalium.UI.Interop NuGet package's
    Content / build-time targets copy each per-backend shared DLL into the
    output. Those copies happen during Interop's own build, where our
    UseJaliumNativeAot flag doesn't propagate, so the file ends up in the
    publish folder. We delete them here as the last step of publish.

    Third-party native DLLs that Jalium.UI.Media transitively pulls in
    (OpenCvSharp, SoundFlow, miniaudio, ffmpeg) are kept by default — they
    belong to managed dependencies that the consumer may legitimately use.
    Set <JaliumStripThirdPartyMediaNatives>true</JaliumStripThirdPartyMediaNatives>
    if your app doesn't touch the video/audio APIs.
  -->
  <Target Name="StripJaliumDuplicateNativeDllsAfterPublish"
          AfterTargets="Publish"
          Condition="'$(UseJaliumNativeAot)' == 'true'">
    <ItemGroup>
      <_JaliumDllsToStrip Include="$(PublishDir)jalium.native.core.dll" />
      <_JaliumDllsToStrip Include="$(PublishDir)jalium.native.d3d12.dll" />
      <_JaliumDllsToStrip Include="$(PublishDir)jalium.native.vulkan.dll" />
      <_JaliumDllsToStrip Include="$(PublishDir)jalium.native.software.dll" />
      <_JaliumDllsToStrip Include="$(PublishDir)jalium.native.platform.dll" />
      <!-- Media DLLs: image / video / camera ABI now ships in jalium.native.media.windows.static.lib
           inside the AOT exe; the dynamic DLLs are pure dead weight after publish. -->
      <_JaliumDllsToStrip Include="$(PublishDir)jalium.native.media.dll" />
      <_JaliumDllsToStrip Include="$(PublishDir)jalium.native.media.core.dll" />
      <!-- jalium.native.browser.dll is removed unconditionally: when
           JaliumIncludeBrowserAot=false the browser feature is excluded; when
           true, the .static.lib is linked instead and the .dll alongside is
           pure dead weight from Interop's Content copy. -->
      <_JaliumDllsToStrip Include="$(PublishDir)jalium.native.browser.dll" />
      <!-- WebView2Loader.dll is replaced by WebView2LoaderStatic.lib in the
           browser-AOT case, and unused entirely in the no-browser case. -->
      <_JaliumDllsToStrip Include="$(PublishDir)WebView2Loader.dll" />
      <_JaliumDllsToStrip Include="$(PublishDir)OpenCvSharpExtern.dll"
                          Condition="'$(JaliumStripThirdPartyMediaNatives)' == 'true'" />
      <_JaliumDllsToStrip Include="$(PublishDir)opencv_videoio_ffmpeg*.dll"
                          Condition="'$(JaliumStripThirdPartyMediaNatives)' == 'true'" />
      <_JaliumDllsToStrip Include="$(PublishDir)miniaudio.dll"
                          Condition="'$(JaliumStripThirdPartyMediaNatives)' == 'true'" />
      <_JaliumDllsToStrip Include="$(PublishDir)soundflow-ffmpeg.dll"
                          Condition="'$(JaliumStripThirdPartyMediaNatives)' == 'true'" />
    </ItemGroup>
    <Delete Files="@(_JaliumDllsToStrip)" ContinueOnError="true">
      <Output TaskParameter="DeletedFiles" ItemName="_JaliumDllsStripped" />
    </Delete>
    <Message Importance="High" Condition="'@(_JaliumDllsStripped)' != ''"
             Text="Jalium NativeAOT: stripped @(_JaliumDllsStripped->'%(Filename)%(Extension)', ', ') (linked statically)." />
  </Target>

</Project>
