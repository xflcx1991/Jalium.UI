                <LinearGradientBrush.GradientStops>
                    <GradientStop Offset="0.33" Color="#66000000" />
                    <GradientStop Offset="1.0" Color="#14FFFFFF" />
                </LinearGradientBrush.GradientStops>
            </LinearGradientBrush>

            <!-- ============================================================ -->
            <!-- WinUI-compat System tokens (Jalium light palette)             -->
            <!-- Alt   = opposite of theme (white on light)                    -->
            <!-- Base  = same as theme foreground (black on light)             -->
