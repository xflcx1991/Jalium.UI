#include <winver.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
FILEFLAGS      0
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_DLL
FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "@JALIUM_COMPANY@\0"
            VALUE "FileDescription",  "@JALIUM_FILE_DESCRIPTION@\0"
            VALUE "FileVersion",      "@PROJECT_VERSION@\0"
            VALUE "InternalName",     "@JALIUM_INTERNAL_NAME@\0"
            VALUE "LegalCopyright",   "@JALIUM_COPYRIGHT@\0"
            VALUE "OriginalFilename", "@JALIUM_ORIGINAL_FILENAME@\0"
            VALUE "ProductName",      "@JALIUM_PRODUCT_NAME@\0"
            VALUE "ProductVersion",   "@PROJECT_VERSION@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
